[Unit]
Description=Askme Frame Capture Daemon (ROS2 → shared file)
After=orbbec-camera.service
Requires=orbbec-camera.service

[Service]
Type=simple
User=sunrise
Environment=ROS_DOMAIN_ID=0
ExecStart=/bin/bash -c "source /opt/ros/humble/setup.bash && python3 /home/sunrise/askme/scripts/frame_daemon.py --rate 5"
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
