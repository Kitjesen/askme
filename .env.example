# ─────────────────────────────────────────────────────────────
# askme — Environment Variables Template
# Copy to .env and fill in your values.
# Lines starting with # are comments.
# ─────────────────────────────────────────────────────────────

# ── LLM Backend (required) ───────────────────────────────────
# Claude relay service API key (format: cr_xxx)
LLM_API_KEY=

# Claude relay base URL (OpenAI-compatible)
LLM_BASE_URL=https://cursor.scihub.edu.kg/api/v1

# ── MiniMax (required for fast voice TTS/LLM) ────────────────
# Get from https://platform.minimax.chat/
MINIMAX_API_KEY=

# ── TTS Voice Settings ────────────────────────────────────────
TTS_VOICE_ID=male-qn-qingse
TTS_SPEED=1
TTS_EMOTION=happy

# ── Local Embeddings (optional, for memory search) ───────────
LOCAL_EMBED_URL=http://localhost:8000/v1

# ── Navigation Service (optional, enables navigate/mapping skills) ──
# nav-gateway REST API base URL
# Without this, navigation skills will tell the user "服务未配置"
# LingTu 部署时设为 http://localhost:5050
NAV_GATEWAY_URL=http://localhost:8088

# ── Telegram Bot (optional, enables Telegram chat interface) ─────
# 从 @BotFather 获取 token，然后在 config.yaml 中设置 platforms.telegram.enabled: true
TELEGRAM_BOT_TOKEN=

# ── Robot Control Service (optional, enables dog_control skill) ──
# dog-control-service base URL
# Without this, posture commands will tell the user "服务未配置"
DOG_CONTROL_SERVICE_URL=http://localhost:5080

# ── Safety Service (optional, enables E-STOP propagation) ────
# dog-safety-service base URL
DOG_SAFETY_SERVICE_URL=http://localhost:5070

# ── Runtime Auth (optional, required if services use auth) ───
RUNTIME_BEARER_TOKEN=
RUNTIME_OPERATOR_ID=askme

# ── NOVA Dog Runtime Bridge (optional, connects to runtime stack) ──
# askme-edge-service base URL
ASKME_EDGE_SERVICE_URL=http://localhost:8090
# NOVA Dog runtime API key
NOVA_DOG_RUNTIME_API_KEY=

# ── OTA Server (optional, enables remote OTA updates) ────────
# Set when OTA is enabled (ota.enabled: true in config.yaml)
OTA_SERVER_URL=
# Device serial number for OTA registration
NOVA_DOG_SERIAL_NUMBER=

# ── Robot Arm Serial Port (optional, for robot_grab/move skills) ──
# Set to actual serial port when not in simulation mode
# Linux: /dev/ttyUSB0  Windows: COM3
ROBOT_SERIAL_PORT=

# ── Feature Flags (override config.yaml sections) ────────────
# ASKME_FEATURE_ROBOT=0      # 1=enable, 0=disable robot arm
# ASKME_FEATURE_VOICE=1      # 1=enable, 0=disable voice I/O
# ASKME_FEATURE_MEMORY=0     # 1=enable, 0=disable memory/RAG

# ── Custom Config Path (optional) ────────────────────────────
# ASKME_CONFIG_PATH=/path/to/config.yaml

# ── Audio Device (optional, for voice mode) ──────────────────
# Override default audio device index (see: python -m sounddevice)
# AUDIO_INPUT_DEVICE=0
# AUDIO_OUTPUT_DEVICE=1
