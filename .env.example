# ============================================================
# Askme MCP Server — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Required: LLM API ---
# Claude Relay Service (OpenAI-compatible)
LLM_API_KEY=cr-your-claude-relay-key
LLM_BASE_URL=https://cursor.scihub.edu.kg/api/v1
# DeepSeek (alternative)
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com

# --- Required for Voice (TTS) ---
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_GROUP_ID=your-group-id

# --- Optional: Embedding Server ---
LOCAL_EMBED_URL=http://localhost:8000/v1

# --- Optional: TTS Voice Tuning ---
TTS_VOICE_ID=male-qn-qingse
TTS_SPEED=1
TTS_EMOTION=happy

# --- Feature Flags (override config.yaml) ---
# ASKME_FEATURE_ROBOT=0      # 1=enable, 0=disable robot arm
# ASKME_FEATURE_VOICE=1      # 1=enable, 0=disable voice I/O
# ASKME_FEATURE_MEMORY=0     # 1=enable, 0=disable memory/RAG

# --- Custom Config Path ---
# ASKME_CONFIG_PATH=/path/to/config.yaml
